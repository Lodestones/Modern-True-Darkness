{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Pitch black night and caves. Yet another modern maintained fork of the 'True Darkness' mod for Fabric!",
  "authors": [
    "Apollo30",
    "https://modrinth.com/mod/modern-true-darkness"
  ],
  "contributors": [
    "HaXr (1.21+ Fabric Port)",
    "Grondag (Original Author)"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/modern-true-darkness",
    "sources": "https://github.com/Lodestones/Modern-True-Darkness",
    "issues": "https://github.com/Lodestones/Modern-True-Darkness/issues"
  },
  "license": "LGPL 3.0",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "grondag.darkness.DarknessInit"
    ],
    "client": [
      "grondag.darkness.DarknessClientInit"
    ],
    "modmenu": [
      "grondag.darkness.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    {
      "config": "${id}.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15",
    "minecraft": "${mcdep}",
    "fabric-api": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/Kss5gBgeDA"
      }
    }
  }
}